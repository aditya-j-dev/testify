generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// ENUMS
// ------------------------------------------------------

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
}

enum QuestionType {
  MCQ_SINGLE
  MCQ_MULTIPLE
  SUBJECTIVE
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  ACTIVE
  COMPLETED
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED    // student submitted cleanly within time
  TIMED_OUT    // server forcibly closed the attempt after expiresAt
}

enum GradingStatus {
  AUTO_GRADED
  MANUAL_REVIEW_PENDING
  FULLY_GRADED
  PUBLISHED
}

enum SyncStatus {
  PENDING   // saved locally, not yet confirmed by server
  SYNCED    // server acknowledged the save
  CONFLICT  // server rejected — timestamp outside exam window
  FAILED    // network/server error; will retry
}

// ------------------------------------------------------
// ORGANIZATION ENTITIES (SaaS Multi-Tenancy)
// ------------------------------------------------------

model College {
  id        String   @id @default(uuid())
  name      String
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  branches  Branch[]
  exams     Exam[]
  subjects  Subject[]
  questions Question[]
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  collegeId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  college    College            @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  batches    Batch[]
  users      User[]
  examAccess ExamAccess[]
  userAccess UserBranchAccess[]

  @@unique([name, collegeId])
}

model Batch {
  id             String   @id @default(uuid())
  name           String
  graduationYear Int
  branchId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branch     Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  users      User[]
  examAccess ExamAccess[]

  @@unique([name, branchId])
}

// ------------------------------------------------------
// CORE USERS
// ------------------------------------------------------

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role

  collegeId String?
  branchId  String?
  batchId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  college College? @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  branch  Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  batch   Batch?   @relation(fields: [batchId], references: [id], onDelete: SetNull)

  examsCreated  Exam[]             @relation("ExamCreator")
  questionsMade Question[]         @relation("QuestionCreator")
  attempts      Attempt[]
  gradedAnswers Answer[]           @relation("AnswerGrader")
  results       Result[]           @relation("StudentResults")
  branchAccess  UserBranchAccess[]
  enrollments   Enrollment[]       @relation("StudentEnrollments")
}

// Allows teachers/admins to be assigned to multiple branches
model UserBranchAccess {
  userId     String
  branchId   String
  assignedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
}

// ------------------------------------------------------
// ACADEMICS & QUESTION BANK
// ------------------------------------------------------

model Subject {
  id        String   @id @default(uuid())
  name      String
  credits   Int      @default(3) // Added for GPA calculation (e.g., 3 or 4 credits)
  collegeId String
  createdAt DateTime @default(now())

  college   College    @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  exams     Exam[]
  questions Question[]
  enrollments Enrollment[]

  @@unique([name, collegeId])
}

model Enrollment {
  id         String   @id @default(uuid())
  studentId  String
  subjectId  String
  semester   Int?     // To group subjects by term for GPA calculation
  enrolledAt DateTime @default(now())

  student    User     @relation("StudentEnrollments", fields: [studentId], references: [id], onDelete: Cascade)
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId])
  @@index([studentId])
  @@index([subjectId])
}

// Replaces Json? options and String[] correctAnswers on Question
model QuestionOption {
  id         String  @id @default(uuid())
  questionId String
  label      String  // e.g. "A", "B", "C", "D"
  text       String
  isCorrect  Boolean @default(false)
  order      Int

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, label])
  @@index([questionId])
}

model Question {
  id           String       @id @default(uuid())
  subjectId    String
  collegeId    String
  creatorId    String
  text         String
  type         QuestionType
  modelAnswer  String?      // reference answer for SUBJECTIVE questions
  defaultMarks Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  subject Subject          @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  college College          @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  creator User             @relation("QuestionCreator", fields: [creatorId], references: [id])
  options QuestionOption[]
  exams   ExamQuestion[]
  answers Answer[]
}

// ------------------------------------------------------
// EXAM ENGINE
// ------------------------------------------------------

model Exam {
  id           String     @id @default(uuid())
  title        String
  description  String?
  semester     Int?       // Tells us if this is a 3rd sem exam, 4th sem exam, etc.
  startTime    DateTime?
  endTime      DateTime?
  duration     Int        // in minutes
  totalMarks   Int
  passingMarks Int?
  status       ExamStatus @default(DRAFT)

  shuffleQuestions Boolean @default(false)
  shuffleOptions   Boolean @default(false)
  allowReview      Boolean @default(true)
  maxAttempts      Int     @default(1)

  collegeId String
  subjectId String
  creatorId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  college   College        @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  subject   Subject        @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  creator   User           @relation("ExamCreator", fields: [creatorId], references: [id])
  questions ExamQuestion[]
  attempts  Attempt[]
  results   Result[]
  access    ExamAccess[]

  @@unique([title, collegeId, subjectId])
  @@index([collegeId])
  @@index([status])
}

// Controls which batches/branches can access an exam
model ExamAccess {
  id       String  @id @default(uuid())
  examId   String
  batchId  String? // if set, only this batch
  branchId String? // if set (without batchId), entire branch gets access

  exam   Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  batch  Batch?  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([examId, batchId])
  @@unique([examId, branchId])
  @@index([examId])
}

model ExamQuestion {
  examId     String
  questionId String
  order      Int
  marks      Int

  // Frozen at publish time — teacher edits to Question won't corrupt live attempts
  questionTextSnapshot   String
  optionsSnapshot        Json?
  correctAnswersSnapshot String[]

  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([examId, questionId])
  @@index([examId, order])
}

// ------------------------------------------------------
// ATTEMPTS & ANSWERS
// ------------------------------------------------------

model Attempt {
  id          String        @id @default(uuid())
  userId      String
  examId      String
  status      AttemptStatus @default(IN_PROGRESS)

  startedAt   DateTime  @default(now())
  expiresAt   DateTime  // = startedAt + exam.duration; server rejects any save after this
  submittedAt DateTime?

  score Float? // running tally before Result is generated

  // Basic proctoring metadata
  ipAddress String?
  userAgent String?
  flagCount Int     @default(0)

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam    Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers Answer[]
  result  Result?
  logs    ProctorLog[]

  @@unique([userId, examId])
  @@index([examId])
  @@index([expiresAt]) // used by background job that force-submits timed-out attempts
}

// ------------------------------------------------------
// ANSWER — with full auto-save / sync support
// ------------------------------------------------------

model Answer {
  id              String   @id @default(uuid())
  attemptId       String
  questionId      String

  // Current committed state
  selectedOptions String[]
  subjectiveText  String?

  // Grading fields
  isCorrect       Boolean?
  marksObtained   Float?
  teacherFeedback String?
  gradedById      String?
  
  // Heartbeat / Auto-save sync fields
  clientSavedAt   DateTime? // Time recorded by browser during interaction
  serverSavedAt   DateTime? // Time recorded by server during sync
  syncStatus      SyncStatus @default(SYNCED)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attempt  Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  gradedBy User?    @relation("AnswerGrader", fields: [gradedById], references: [id])
  history  AnswerHistory[]

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([syncStatus])
}


// Append-only audit log — one row per background sync or reconcile event.
// Used for: timeline reconstruction, dispute resolution, proctoring audit.
model AnswerHistory {
  id       String @id @default(uuid())
  answerId String

  selectedOptions String[]
  subjectiveText  String?

  // Raw client timestamp — stored as-is for audit even if later rejected.
  clientSavedAt DateTime

  // Server wall-clock time when this row was written — always trusted.
  serverReceivedAt DateTime @default(now())

  // Was this save rejected by anti-cheat validation?
  wasRejected     Boolean @default(false)
  rejectionReason String? // e.g. "OUTSIDE_EXAM_WINDOW" | "ATTEMPT_EXPIRED" | "CLOCK_SKEW"

  // Origin of this history entry:
  // "BACKGROUND_SYNC"        — periodic auto-save from client
  // "FINAL_SUBMIT_RECONCILE" — pushed during final submit because it was newer
  // "MANUAL"                 — teacher/admin correction
  source String @default("BACKGROUND_SYNC")

  answer Answer @relation(fields: [answerId], references: [id], onDelete: Cascade)

  @@index([answerId])
  @@index([clientSavedAt])
}

// Proctoring event log — one row per browser integrity event.
model ProctorLog {
  id        String @id @default(uuid())
  attemptId String

  // e.g. "TAB_SWITCH" | "BLUR" | "FOCUS" | "COPY" | "PASTE" |
  //      "FULLSCREEN_EXIT" | "DEVTOOLS_OPEN" | "RIGHT_CLICK" | "IDLE_TIMEOUT"
  event    String
  metadata Json?  // extra payload: timestamp delta, clipboard length, etc.

  createdAt DateTime @default(now())

  attempt Attempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([attemptId])
  @@index([event])
}

// ------------------------------------------------------
// RESULT ENGINE
// ------------------------------------------------------

model Result {
  id        String @id @default(uuid())
  attemptId String @unique
  studentId String
  examId    String

  totalMarksObtained Float   @default(0)
  percentage         Float?  // derived — always recompute before trusting stored value
  isPassed           Boolean?
  gradePoint         Float?  // e.g., 4.0, 3.0 — multiplied by Subject.credits for GPA

  gradingStatus   GradingStatus @default(MANUAL_REVIEW_PENDING)
  overallFeedback String?
  publishedAt     DateTime? // when result became visible to the student

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attempt Attempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  student User    @relation("StudentResults", fields: [studentId], references: [id], onDelete: Cascade)
  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@index([studentId])
  @@index([gradingStatus])
}
