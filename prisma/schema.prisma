// =============================================================================
// PRISMA SCHEMA — Exam Platform (SaaS Multi-Tenant)
// Includes: College Registration, Trial/Subscription, Payments, Cancellation,
//           Question Bank, Exam Engine, Attempts, Auto-Save, Proctoring, Results
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum Role {
  SUPER_ADMIN  // Monitors all colleges and their admins
  ADMIN        // College-level admin, manages everything within their college
  TEACHER      // Creates/publishes exams, grades answers, publishes results
  STUDENT      // Takes exams, views results
}

enum QuestionType {
  MCQ_SINGLE    // Single correct answer
  MCQ_MULTIPLE  // Multiple correct answers
  SUBJECTIVE    // Long-form answer, manually graded
}

enum ExamStatus {
  DRAFT      // Being built by teacher, not visible to students
  PUBLISHED  // Visible and accessible to assigned batches
  ACTIVE     // Currently running (within startTime–endTime window)
  COMPLETED  // Past endTime, no more attempts allowed
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED    // student submitted cleanly within time
  TIMED_OUT    // server forcibly closed the attempt after expiresAt
  CHEATED      // auto-submitted due to proctoring violation
}

enum GradingStatus {
  AUTO_GRADED           // All MCQ, no manual review needed
  MANUAL_REVIEW_PENDING // Has SUBJECTIVE questions pending teacher review
  FULLY_GRADED          // All answers graded
  PUBLISHED             // Result visible to student
}

enum SyncStatus {
  PENDING  // Saved locally, not yet confirmed by server
  SYNCED   // Server acknowledged the save
  CONFLICT // Server rejected — timestamp outside exam window
  FAILED   // Network/server error; will retry
}

enum SubscriptionStatus {
  TRIAL          // Within the 3-day trial window, limited features
  TRIAL_EXPIRED  // Trial ended, payment not done — dashboard locked
  ACTIVE         // Paid and fully active
  SUSPENDED      // Payment failed or lapsed mid-subscription
  CANCELLED      // College explicitly cancelled or churned
}

enum PlanType {
  TRIAL        // 3-day, heavily limited
  STARTER      // Entry paid tier
  PROFESSIONAL // Mid tier
  ENTERPRISE   // Full-featured, custom pricing
}

enum PaymentStatus {
  PENDING   // Order created, awaiting gateway capture
  SUCCESS   // Payment confirmed by gateway webhook
  FAILED    // Gateway returned failure
  REFUNDED  // Payment refunded
}

// =============================================================================
// ONBOARDING — Landing Page Registration (Pre-College)
// =============================================================================

// Captures the "Get Started" form from the landing page.
// This is created BEFORE the College row. It is the source of truth
// for the onboarding funnel. Once provisioned, it links to College + User.
model CollegeRegistration {
  id            String    @id @default(uuid())

  // Fields collected from the landing page form
  collegeName   String
  contactName   String
  contactEmail  String    @unique
  contactPhone  String?
  designation   String?   // e.g. "Principal", "HOD", "IT Admin"
  address       String?

  // Populated by the provisioning job after College + Admin User are created
  collegeId     String?   @unique
  adminUserId   String?   @unique

  // Account setup tracking
  setupToken        String?   // Signed JWT sent in the welcome email for password setup
  setupTokenSentAt  DateTime? // When the welcome email was dispatched
  setupCompletedAt  DateTime? // null = admin never clicked the link and set a password

  // Provisioning state
  isProvisioned Boolean   @default(false) // true once College + User rows are created
  provisionedAt DateTime?

  createdAt     DateTime  @default(now())

  // Relations (both nullable until provisioned)
  college   College? @relation(fields: [collegeId], references: [id])
  adminUser User?    @relation("RegistrationSourceUser", fields: [adminUserId], references: [id])
}

// =============================================================================
// SUBSCRIPTION PLAN CATALOG
// =============================================================================

// Defines what each plan allows. Trial limits live here.
// Changing limits = one DB row update, zero code changes.
model SubscriptionPlan {
  id           String   @id @default(uuid())
  name         String   // Human-readable: "Trial", "Starter", "Professional"
  planType     PlanType @unique
  priceInPaise Int      // Stored in smallest currency unit (paise for INR)
  currency     String   @default("INR")
  durationDays Int      // 3 for Trial, 30 for monthly, 365 for annual

  // Resource caps — null means unlimited (for paid plans)
  maxBranches  Int?     // Trial = 1
  maxBatches   Int?     // Trial = 1
  maxTeachers  Int?     // Trial = 1
  maxStudents  Int?     // Trial = 1
  maxExams     Int?     // Trial = 1

  // Feature flags — extensible without schema migration
  // Example: { "proctoring": false, "analytics": false, "bulkImport": false, "apiAccess": false }
  features     Json?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =============================================================================
// ORGANIZATION ENTITIES (SaaS Multi-Tenancy)
// =============================================================================

model College {
  id        String   @id @default(uuid())
  name      String
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ---------- Subscription & Lifecycle ----------
  subscriptionStatus  SubscriptionStatus @default(TRIAL)
  planType            PlanType           @default(TRIAL)

  // Trial window
  trialEndsAt         DateTime?          // Set to createdAt + 3 days on provisioning

  // Active billing window (populated after payment)
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?

  // Soft delete / lifecycle
  scheduledDeletionAt DateTime?          // Set when cleanup is queued (before hard delete)
  deletedAt           DateTime?          // Soft delete — set this instead of deleting the row
  deletionReason      String?            // "TRIAL_EXPIRED_NO_PAYMENT" | "EXPLICIT_CANCEL" | "ADMIN_ACTION"

  // ---------- Core Academic Relations ----------
  users     User[]
  branches  Branch[]
  exams     Exam[]
  subjects  Subject[]
  questions Question[]

  // ---------- Subscription Relations ----------
  registration        CollegeRegistration?
  payments            Payment[]
  subscriptions       CollegeSubscription[]
  cancellationRequest CancellationRequest?
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  collegeId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  college    College            @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  batches    Batch[]
  users      User[]
  examAccess ExamAccess[]
  userAccess UserBranchAccess[]

  @@unique([name, collegeId])
}

model Batch {
  id             String   @id @default(uuid())
  name           String
  graduationYear Int
  branchId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branch     Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  users      User[]
  examAccess ExamAccess[]

  @@unique([name, branchId])
}

// =============================================================================
// CORE USERS
// =============================================================================

model User {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String
  name         String
  role         Role

  collegeId String?
  branchId  String?
  batchId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  college College? @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  branch  Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  batch   Batch?   @relation(fields: [batchId], references: [id], onDelete: SetNull)

  examsCreated  Exam[]             @relation("ExamCreator")
  questionsMade Question[]         @relation("QuestionCreator")
  attempts      Attempt[]
  gradedAnswers Answer[]           @relation("AnswerGrader")
  results       Result[]           @relation("StudentResults")
  branchAccess  UserBranchAccess[]
  enrollments   Enrollment[]       @relation("StudentEnrollments")

  // Only populated for the founding admin of a college (the person who filled the form)
  registrationSource    CollegeRegistration? @relation("RegistrationSourceUser")

  // Only populated if this admin raised a cancellation request
  cancellationRequests  CancellationRequest[] @relation("CancellationRequester")
}

// Allows teachers/admins to be assigned to multiple branches
model UserBranchAccess {
  userId     String
  branchId   String
  assignedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
}

// =============================================================================
// ACADEMICS & QUESTION BANK
// =============================================================================

model Subject {
  id        String   @id @default(uuid())
  name      String
  credits   Int      @default(3) // For GPA calculation (e.g., 3 or 4 credits)
  collegeId String
  createdAt DateTime @default(now())

  college     College      @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  exams       Exam[]
  questions   Question[]
  enrollments Enrollment[]

  @@unique([name, collegeId])
}

// Tracks which students are enrolled in which subjects and which semester
model Enrollment {
  id         String   @id @default(uuid())
  studentId  String
  subjectId  String
  semester   Int?     // Groups subjects by term for GPA calculation
  enrolledAt DateTime @default(now())

  student    User     @relation("StudentEnrollments", fields: [studentId], references: [id], onDelete: Cascade)
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId])
  @@index([studentId])
  @@index([subjectId])
}

// Normalized options for MCQ questions (replaces Json? options field)
model QuestionOption {
  id         String  @id @default(uuid())
  questionId String
  label      String  // e.g. "A", "B", "C", "D"
  text       String
  isCorrect  Boolean @default(false)
  order      Int

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, label])
  @@index([questionId])
}

model Question {
  id           String       @id @default(uuid())
  subjectId    String
  collegeId    String
  creatorId    String
  text         String
  type         QuestionType
  modelAnswer  String?      // Reference answer for SUBJECTIVE questions
  defaultMarks Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  subject Subject          @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  college College          @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  creator User             @relation("QuestionCreator", fields: [creatorId], references: [id])
  options QuestionOption[]
  exams   ExamQuestion[]
  answers Answer[]
}

// =============================================================================
// EXAM ENGINE
// =============================================================================

model Exam {
  id           String     @id @default(uuid())
  title        String
  description  String?
  semester     Int?       // e.g. 3rd sem exam, 4th sem exam
  startTime    DateTime?
  endTime      DateTime?
  duration     Int        // In minutes
  totalMarks   Int
  passingMarks Int?
  status       ExamStatus @default(DRAFT)

  shuffleQuestions Boolean @default(false)
  shuffleOptions   Boolean @default(false)
  allowReview      Boolean @default(true)
  maxAttempts      Int     @default(1)

  collegeId String
  subjectId String
  creatorId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  college   College        @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  subject   Subject        @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  creator   User           @relation("ExamCreator", fields: [creatorId], references: [id])
  questions ExamQuestion[]
  attempts  Attempt[]
  results   Result[]
  access    ExamAccess[]

  @@unique([title, collegeId, subjectId])
  @@index([collegeId])
  @@index([status])
}

// Controls which batches/branches can access an exam
model ExamAccess {
  id       String  @id @default(uuid())
  examId   String
  batchId  String? // If set, only this batch gets access
  branchId String? // If set (without batchId), entire branch gets access

  exam   Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  batch  Batch?  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([examId, batchId])
  @@unique([examId, branchId])
  @@index([examId])
}

// Snapshot of question at publish time — teacher edits won't corrupt live attempts
model ExamQuestion {
  examId     String
  questionId String
  order      Int
  marks      Int

  // Frozen at publish time — teacher edits to Question won't corrupt live attempts
  questionTextSnapshot   String
  optionsSnapshot        Json?
  correctAnswersSnapshot String[]

  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([examId, questionId])
  @@index([examId, order])
}

// =============================================================================
// ATTEMPTS & ANSWERS
// =============================================================================

model Attempt {
  id     String        @id @default(uuid())
  userId String
  examId String
  status AttemptStatus @default(IN_PROGRESS)

  startedAt   DateTime  @default(now())
  expiresAt   DateTime  // = startedAt + exam.duration; server rejects saves after this
  submittedAt DateTime?

  score Float? // Running tally before Result is generated

  // Basic proctoring metadata
  ipAddress String?
  userAgent String?
  flagCount Int     @default(0)

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam    Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers Answer[]
  result  Result?
  logs    ProctorLog[]

  @@unique([userId, examId])
  @@index([examId])
  @@index([expiresAt]) // Used by background job that force-submits timed-out attempts
}

// Answer with full auto-save / sync support
model Answer {
  id         String @id @default(uuid())
  attemptId  String
  questionId String

  // Current committed state
  selectedOptions String[]
  subjectiveText  String?

  // Grading fields
  isCorrect       Boolean?
  marksObtained   Float?
  teacherFeedback String?
  gradedById      String?

  // Heartbeat / Auto-save sync fields
  clientSavedAt DateTime?  // Timestamp recorded by browser during interaction
  serverSavedAt DateTime?  // Timestamp recorded by server during sync
  syncStatus    SyncStatus @default(SYNCED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attempt  Attempt       @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  gradedBy User?         @relation("AnswerGrader", fields: [gradedById], references: [id])
  history  AnswerHistory[]

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([syncStatus])
}

// Append-only audit log — one row per background sync or reconcile event
// Used for: timeline reconstruction, dispute resolution, proctoring audit
model AnswerHistory {
  id       String @id @default(uuid())
  answerId String

  selectedOptions String[]
  subjectiveText  String?

  // Raw client timestamp — stored as-is for audit even if later rejected
  clientSavedAt DateTime

  // Server wall-clock time when this row was written — always trusted
  serverReceivedAt DateTime @default(now())

  // Was this save rejected by anti-cheat validation?
  wasRejected     Boolean @default(false)
  rejectionReason String? // "OUTSIDE_EXAM_WINDOW" | "ATTEMPT_EXPIRED" | "CLOCK_SKEW"

  // Origin of this entry:
  // "BACKGROUND_SYNC"        — periodic auto-save from client
  // "FINAL_SUBMIT_RECONCILE" — pushed during final submit because it was newer
  // "MANUAL"                 — teacher/admin correction
  source String @default("BACKGROUND_SYNC")

  answer Answer @relation(fields: [answerId], references: [id], onDelete: Cascade)

  @@index([answerId])
  @@index([clientSavedAt])
}

// Proctoring event log — one row per browser integrity event
model ProctorLog {
  id        String @id @default(uuid())
  attemptId String

  // Event types: "TAB_SWITCH" | "BLUR" | "FOCUS" | "COPY" | "PASTE" |
  //              "FULLSCREEN_EXIT" | "DEVTOOLS_OPEN" | "RIGHT_CLICK" | "IDLE_TIMEOUT"
  event    String
  metadata Json?  // Extra payload: timestamp delta, clipboard length, etc.

  createdAt DateTime @default(now())

  attempt Attempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([attemptId])
  @@index([event])
}

// =============================================================================
// RESULT ENGINE
// =============================================================================

model Result {
  id        String @id @default(uuid())
  attemptId String @unique
  studentId String
  examId    String

  totalMarksObtained Float    @default(0)
  percentage         Float?   // Derived — always recompute before trusting stored value
  isPassed           Boolean?
  gradePoint         Float?   // e.g., 4.0, 3.0 — multiplied by Subject.credits for GPA

  gradingStatus   GradingStatus @default(MANUAL_REVIEW_PENDING)
  overallFeedback String?
  publishedAt     DateTime?     // When result became visible to the student

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attempt Attempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  student User    @relation("StudentResults", fields: [studentId], references: [id], onDelete: Cascade)
  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@index([studentId])
  @@index([gradingStatus])
}

// =============================================================================
// PAYMENT & SUBSCRIPTION
// =============================================================================

// One row per payment attempt — gateway-agnostic ledger
model Payment {
  id            String        @id @default(uuid())
  collegeId     String

  amountInPaise Int           // Amount in smallest currency unit (paise for INR)
  currency      String        @default("INR")
  status        PaymentStatus @default(PENDING)
  planType      PlanType      // Which plan this payment is for

  // Gateway fields — populated after initiation / on webhook
  gateway          String  // "razorpay" | "stripe"
  gatewayOrderId   String? // Order/session ID created on your backend
  gatewayPaymentId String? // Payment ID returned by gateway on success
  gatewaySignature String? // For Razorpay signature verification

  // Billing window this payment covers
  billingPeriodStart DateTime?
  billingPeriodEnd   DateTime?

  failureReason String?   // Populated on FAILED status
  paidAt        DateTime? // Set on SUCCESS
  refundedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  college      College              @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  subscription CollegeSubscription?

  @@index([collegeId])
  @@index([status])
  @@index([gatewayOrderId])
  @@index([gatewayPaymentId])
}

// Active subscription record — one active row per college at a time
model CollegeSubscription {
  id        String   @id @default(uuid())
  collegeId String
  paymentId String?  @unique // The payment that activated this subscription
  planType  PlanType

  startedAt DateTime
  expiresAt DateTime
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  college College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id])

  @@index([collegeId])
  @@index([isActive])
  @@index([expiresAt]) // Used by cron job to expire subscriptions
}

// =============================================================================
// CANCELLATION
// =============================================================================

// Tracks explicit cancellation requests with a grace period before deletion
model CancellationRequest {
  id          String   @id @default(uuid())
  collegeId   String   @unique  // Only one active cancellation per college at a time
  requestedBy String

  reason      String?  // Optional: from a "why are you leaving?" dropdown
  requestedAt DateTime @default(now())

  // Grace period — data is NOT deleted immediately
  // For trial cancellations: scheduledAt = requestedAt + 7 days
  // For paid cancellations:  scheduledAt = currentPeriodEnd + 7 days
  scheduledAt DateTime

  processedAt DateTime? // Set when cron job actually deletes the college

  college         College @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  requestedByUser User    @relation("CancellationRequester", fields: [requestedBy], references: [id])
}
